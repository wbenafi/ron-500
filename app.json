{
  "expo": {
    "name": "RON 500",
    "slug": "ron-500",
    "scheme": "ron500",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.walterbenavides.ron500",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "543abdd1-7ee2-4687-9ab8-d36b246e4aef"
      }
    },
    "owner": "walter03bf"
  }
}
